@{
    var title = ViewData["Title"]?.ToString() ?? "Dapper Panel";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@title</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        * {
            box-sizing: border-box;
        }

        :root {
            --bg: #07111f;
            --bg2: #0b1728;
            --panel: rgba(15, 23, 42, 0.88);
            --panel-2: rgba(17, 24, 39, 0.95);
            --border: rgba(255,255,255,.08);
            --text: #e5eefc;
            --muted: #8ea4c7;
            --blue: #4f8cff;
            --blue2: #2563eb;
            --cyan: #22d3ee;
            --green: #22c55e;
            --purple: #8b5cf6;
            --orange: #f59e0b;
            --pink: #ec4899;
            --shadow: 0 18px 40px rgba(0,0,0,.28);
        }

        body {
            margin: 0;
            font-family: "Segoe UI", Arial, sans-serif;
            color: var(--text);
            background: radial-gradient(circle at top left, rgba(79,140,255,.16), transparent 25%), radial-gradient(circle at top right, rgba(139,92,246,.12), transparent 25%), linear-gradient(135deg, var(--bg), var(--bg2));
            min-height: 100vh;
        }

        .app {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 270px;
            background: linear-gradient(180deg, rgba(8,15,30,.95), rgba(11,23,40,.98));
            backdrop-filter: blur(18px);
            border-right: 1px solid var(--border);
            padding: 40px 18px 24px 18px;
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .menu a {
            display: flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
            color: var(--text);
            padding: 15px 16px;
            border-radius: 16px;
            margin-bottom: 12px;
            background: rgba(255,255,255,.03);
            border: 1px solid transparent;
            transition: .25s ease;
            position: relative;
            overflow: hidden;
        }

            .menu a i {
                width: 20px;
                text-align: center;
            }

            .menu a:hover {
                transform: translateX(4px);
                background: rgba(79,140,255,.12);
                border-color: rgba(79,140,255,.16);
            }

            .menu a.active {
                background: linear-gradient(135deg, rgba(79,140,255,.22), rgba(37,99,235,.18));
                border-color: rgba(79,140,255,.28);
                box-shadow: 0 12px 28px rgba(37,99,235,.18);
            }

                .menu a.active::before {
                    content: "";
                    position: absolute;
                    left: 0;
                    top: 10px;
                    bottom: 10px;
                    width: 4px;
                    border-radius: 999px;
                    background: linear-gradient(180deg, var(--cyan), var(--blue));
                }

        .content {
            flex: 1;
            padding: 28px;
        }

        .topbar {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            margin-bottom: 26px;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .top-chip {
            background: rgba(255,255,255,.05);
            border: 1px solid var(--border);
            color: #dbeafe;
            padding: 10px 14px;
            border-radius: 999px;
            font-size: 13px;
            backdrop-filter: blur(12px);
        }

        .avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--purple), var(--blue));
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            box-shadow: 0 10px 20px rgba(79,140,255,.25);
        }

        .panel {
            background: linear-gradient(180deg, rgba(12,23,42,.92), rgba(9,18,33,.96));
            border: 1px solid var(--border);
            border-radius: 24px;
            padding: 22px;
            box-shadow: var(--shadow);
            backdrop-filter: blur(14px);
        }

        .section-title {
            font-size: 19px;
            font-weight: 800;
            margin-bottom: 18px;
            color: #f8fbff;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            padding: 14px 12px;
            text-align: left;
            border-bottom: 1px solid rgba(255,255,255,.06);
            font-size: 14px;
        }

        th {
            color: #8fb3df;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 12px;
            letter-spacing: .6px;
        }

        tr:hover {
            background: rgba(255,255,255,.03);
        }

        .btn-nav {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            background: linear-gradient(135deg, var(--blue), var(--blue2));
            color: white;
            padding: 10px 16px;
            border-radius: 12px;
            margin-right: 8px;
            box-shadow: 0 10px 24px rgba(37,99,235,.24);
            transition: .2s;
        }

            .btn-nav:hover {
                transform: translateY(-2px);
                color: white;
            }

        @@media (max-width: 960px) {
            .app {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
                height: auto;
                position: relative;
            }
        }
    </style>
</head>
<body>
    <div class="app">
        <aside class="sidebar">
            <nav class="menu">
                <a href="/Dashboard/Index" class="@(currentController == "Dashboard" ? "active" : "")">
                    <i class="fa-solid fa-gauge-high"></i>
                    <span>Dashboard</span>
                </a>

                <a href="/Sales/Index" class="@(currentController == "Sales" ? "active" : "")">
                    <i class="fa-solid fa-table-list"></i>
                    <span>Veriler</span>
                </a>
            </nav>
        </aside>

        <main class="content">
            <div class="topbar">
                <div class="topbar-right">
                    <div class="top-chip">
                        <i class="fa-solid fa-circle-check"></i> Sistem Aktif
                    </div>
                    <div class="avatar">D</div>
                </div>
            </div>

            @RenderBody()
        </main>
    </div>
</body>
</html>