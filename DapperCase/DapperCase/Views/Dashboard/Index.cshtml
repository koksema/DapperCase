@model DapperCase.Dtos.DashboardDto
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        margin-bottom: 26px;
    }

    .metric-card {
        position: relative;
        overflow: hidden;
        border-radius: 22px;
        padding: 22px;
        border: 1px solid rgba(255,255,255,.06);
        background: linear-gradient(180deg, rgba(16,27,48,.95), rgba(10,19,34,.98));
        box-shadow: 0 18px 34px rgba(0,0,0,.24);
    }

        .metric-card::after {
            content: "";
            position: absolute;
            right: -10px;
            top: -10px;
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,255,255,.10), transparent 70%);
        }

    .metric-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 18px;
    }

    .metric-icon {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .mi-1 {
        background: rgba(79,140,255,.18);
        color: #60a5fa;
    }

    .mi-2 {
        background: rgba(34,197,94,.16);
        color: #4ade80;
    }

    .mi-3 {
        background: rgba(139,92,246,.16);
        color: #c084fc;
    }

    .mi-4 {
        background: rgba(245,158,11,.16);
        color: #fbbf24;
    }

    .metric-badge {
        font-size: 12px;
        color: #9dd6ff;
        background: rgba(79,140,255,.10);
        border: 1px solid rgba(79,140,255,.18);
        border-radius: 999px;
        padding: 6px 10px;
    }

    .metric-card h6 {
        color: #8ea4c7;
        margin: 0 0 8px 0;
        font-size: 13px;
        letter-spacing: .3px;
    }

    .metric-card h2 {
        font-size: 30px;
        margin: 0 0 8px 0;
        color: #fff;
    }

    .metric-card p {
        margin: 0;
        color: #9fb1cc;
        font-size: 13px;
    }

    .grid-main {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-bottom: 22px;
    }
    .grid-bottom {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
    }

    .highlight-boxes {
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
        margin-bottom: 18px;
    }

    .highlight-box {
        padding: 16px;
        border-radius: 16px;
        background: rgba(255,255,255,.03);
        border: 1px solid rgba(255,255,255,.05);
    }

        .highlight-box span {
            display: block;
            color: #8ea4c7;
            font-size: 12px;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: .7px;
        }

        .highlight-box strong {
            font-size: 20px;
            color: #fff;
        }

    .table-accent-1 {
        border-top: 3px solid #22c55e;
    }

    .table-accent-2 {
        border-top: 3px solid #60a5fa;
    }

    .number-good {
        color: #4ade80;
        font-weight: 700;
    }

    .number-strong {
        color: #f8fbff;
        font-weight: 700;
    }

    .chart-panel {
        margin-bottom: 22px;
    }

    .chart-subtitle {
        color: #8ea4c7;
        font-size: 13px;
        margin-top: -8px;
        margin-bottom: 14px;
    }

    @@media (max-width: 1200px) {
        .cards {
            grid-template-columns: repeat(2, 1fr);
        }

        .grid-main,
        .grid-bottom {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 700px) {
        .cards {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="cards">
    <div class="metric-card">
        <div class="metric-top">
            <div class="metric-icon mi-1"><i class="fa-solid fa-wallet"></i></div>
            <div class="metric-badge">Revenue</div>
        </div>
        <h6>Toplam Satış</h6>
        <h2>@Model.TotalRevenue.ToString("N2") ₺</h2>
        <p>Genel toplam satış hacmi</p>
    </div>

    <div class="metric-card">
        <div class="metric-top">
            <div class="metric-icon mi-2"><i class="fa-solid fa-sack-dollar"></i></div>
            <div class="metric-badge">Profit</div>
        </div>
        <h6>Toplam Kâr</h6>
        <h2>@Model.TotalProfit.ToString("N2") ₺</h2>
        <p>Net profit toplamı</p>
    </div>

    <div class="metric-card">
        <div class="metric-top">
            <div class="metric-icon mi-3"><i class="fa-solid fa-cart-shopping"></i></div>
            <div class="metric-badge">Orders</div>
        </div>
        <h6>Toplam Sipariş</h6>
        <h2>@Model.TotalOrders</h2>
        <p>Sisteme kayıtlı toplam sipariş</p>
    </div>

    <div class="metric-card">
        <div class="metric-top">
            <div class="metric-icon mi-4"><i class="fa-solid fa-users"></i></div>
            <div class="metric-badge">Customers</div>
        </div>
        <h6>Toplam Müşteri</h6>
        <h2>@Model.TotalCustomers</h2>
        <p>Farklı müşteri sayısı</p>
    </div>

    <div class="metric-card">
        <div class="metric-top">
            <div class="metric-icon mi-1"><i class="fa-solid fa-basket-shopping"></i></div>
            <div class="metric-badge">Avg</div>
        </div>
        <h6>Ortalama Sepet</h6>
        <h2>@Model.AverageBasket.ToString("N2") ₺</h2>
        <p>Ortalama order revenue</p>
    </div>

    <div class="metric-card">
        <div class="metric-top">
            <div class="metric-icon mi-2"><i class="fa-solid fa-crown"></i></div>
            <div class="metric-badge">Best</div>
        </div>
        <h6>En İyi Müşteri</h6>
        <h2>@Model.TopCustomer</h2>
        <p>En yüksek ciroya sahip müşteri</p>
    </div>

    <div class="metric-card">
        <div class="metric-top">
            <div class="metric-icon mi-3"><i class="fa-solid fa-star"></i></div>
            <div class="metric-badge">Top</div>
        </div>
        <h6>En Büyük Sipariş</h6>
        <h2>@Model.TopOrder</h2>
        <p>En yüksek revenue üreten order</p>
    </div>

    <div class="metric-card">
        <div class="metric-top">
            <div class="metric-icon mi-4"><i class="fa-solid fa-chart-simple"></i></div>
            <div class="metric-badge">Status</div>
        </div>
        <h6>Panel Durumu</h6>
        <h2>Aktif</h2>
        <p>Dashboard sorunsuz çalışıyor</p>
    </div>
</div>

<div class="grid-main">
    <div class="panel">
        <div class="section-title">En Yüksek Ciroya Sahip Müşteriler</div>
        <canvas id="revenueChart" height="250"></canvas>
    </div>
    <div class="panel">
        <div class="section-title">Kâr Dağılımı</div>
        <canvas id="profitChart" height="150"></canvas>
    </div>
</div>

<div class="panel chart-panel">
    <div class="section-title">Revenue ve Profit Karşılaştırması</div>
    <div class="chart-subtitle">Son 10 sipariş için bar ve line grafik birlikte gösteriliyor</div>
    <canvas id="mixedChart" height="110"></canvas>
</div>

<div class="grid-bottom">
    <div class="panel table-accent-1">
        <div class="section-title">En Çok Alışveriş Yapan 5 Müşteri</div>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Müşteri</th>
                    <th>Satış</th>
                    <th>Kâr</th>
                    <th>Adet</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.TopCustomers.Count; i++)
                {
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@Model.TopCustomers[i].customer_id</td>
                        <td class="number-strong">@Model.TopCustomers[i].total_revenue.ToString("N2")</td>
                        <td class="number-good">@Model.TopCustomers[i].total_profit.ToString("N2")</td>
                        <td>@Model.TopCustomers[i].order_count</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="panel table-accent-2">
        <div class="section-title">En Büyük 5 Sipariş</div>
        <table>
            <thead>
                <tr>
                    <th>#</th>
                    <th>Order</th>
                    <th>Müşteri</th>
                    <th>Revenue</th>
                    <th>Profit</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.TopOrders.Count; i++)
                {
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@Model.TopOrders[i].order_id</td>
                        <td>@Model.TopOrders[i].customer_id</td>
                        <td class="number-strong">@Model.TopOrders[i].revenue.ToString("N2")</td>
                        <td class="number-good">@Model.TopOrders[i].profit.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    const revenueLabels = @Html.Raw(JsonSerializer.Serialize(Model.RevenueChartLabels));
    const revenueValues = @Html.Raw(JsonSerializer.Serialize(Model.RevenueChartValues));

    const profitLabels = @Html.Raw(JsonSerializer.Serialize(Model.ProfitChartLabels));
    const profitValues = @Html.Raw(JsonSerializer.Serialize(Model.ProfitChartValues));

    const mixedLabels = @Html.Raw(JsonSerializer.Serialize(Model.MixedChartLabels));
    const mixedRevenueValues = @Html.Raw(JsonSerializer.Serialize(Model.MixedRevenueValues));
    const mixedProfitValues = @Html.Raw(JsonSerializer.Serialize(Model.MixedProfitValues));

    new Chart(document.getElementById('revenueChart'), {
        type: 'bar',
        data: {
            labels: revenueLabels,
            datasets: [{
                label: 'Revenue',
                data: revenueValues,
                backgroundColor: [
                    'rgba(79,140,255,0.85)',
                    'rgba(34,197,94,0.85)',
                    'rgba(245,158,11,0.85)',
                    'rgba(139,92,246,0.85)',
                    'rgba(236,72,153,0.85)',
                    'rgba(34,211,238,0.85)'
                ],
                borderRadius: 10,
                borderSkipped: false
            }]
        },
        options: {
            plugins: {
                legend: {
                    labels: { color: '#e5eefc' }
                }
            },
            scales: {
                x: {
                    ticks: { color: '#d7e5fb' },
                    grid: { color: 'rgba(255,255,255,.04)' }
                },
                y: {
                    ticks: { color: '#d7e5fb' },
                    grid: { color: 'rgba(255,255,255,.04)' }
                }
            }
        }
    });

    new Chart(document.getElementById('profitChart'), {
        type: 'doughnut',
        data: {
            labels: profitLabels,
            datasets: [{
                data: profitValues,
                backgroundColor: [
                    '#4f8cff',
                    '#22c55e',
                    '#f59e0b',
                    '#8b5cf6',
                    '#ec4899',
                    '#22d3ee'
                ],
                borderWidth: 0
            }]
        },
        options: {
            plugins: {
                legend: {
                    labels: { color: '#e5eefc' }
                }
            }
        }
    });

    new Chart(document.getElementById('mixedChart'), {
        data: {
            labels: mixedLabels,
            datasets: [
                {
                    type: 'bar',
                    label: 'Revenue',
                    data: mixedRevenueValues,
                    backgroundColor: 'rgba(79,140,255,0.75)',
                    borderRadius: 8,
                    borderSkipped: false,
                    yAxisID: 'y'
                },
                {
                    type: 'line',
                    label: 'Profit',
                    data: mixedProfitValues,
                    borderColor: '#34d399',
                    backgroundColor: 'rgba(52,211,153,0.15)',
                    fill: false,
                    tension: 0.35,
                    borderWidth: 3,
                    pointBackgroundColor: '#34d399',
                    pointRadius: 4,
                    yAxisID: 'y1'
                }
            ]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    labels: { color: '#e5eefc' }
                }
            },
            scales: {
                x: {
                    ticks: { color: '#d7e5fb' },
                    grid: { color: 'rgba(255,255,255,.04)' }
                },
                y: {
                    position: 'left',
                    ticks: { color: '#d7e5fb' },
                    grid: { color: 'rgba(255,255,255,.04)' }
                },
                y1: {
                    position: 'right',
                    ticks: { color: '#d7e5fb' },
                    grid: { drawOnChartArea: false }
                }
            }
        }
    });
</script>